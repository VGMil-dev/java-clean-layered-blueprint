---
import * as Lucide from "lucide-astro";

interface Props {
    title: string;
    icon?: keyof typeof Lucide;
}

const { title, icon } = Astro.props;
const IconComponent = icon ? (Lucide[icon] as any) : null;
---

<div class="relative group h-full transition-all duration-500 overflow-visible">
    <div
        class="relative h-full bg-[var(--sl-color-bg)] rounded-[15px] p-6 flex flex-col gap-5 overflow-hidden border border-[var(--swing-card-border)] group-hover:border-[var(--sl-color-accent)]/30 transition-colors duration-500"
    >
        <div
            class="absolute -right-12 -top-12 w-40 h-40 bg-[var(--sl-color-accent)] opacity-0 group-hover:opacity-20 blur-[60px] transition-opacity duration-700 rounded-full pointer-events-none"
        >
        </div>

        <div class="flex items-center gap-4 relative z-10 h-10">
            {
                IconComponent && (
                    <div class="flex-shrink-0 p-2 bg-[var(--sl-color-gray-6)] rounded-xl border border-[var(--sl-color-gray-5)] text-[var(--sl-color-accent)] group-hover:text-[var(--gold-primary)] group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-lg">
                        <IconComponent size={22} stroke-width={2} />
                    </div>
                )
            }
            <h3
                class="text-xl font-bold text-[var(--sl-color-gray-1)] transition-colors duration-500 group-hover:text-[var(--gold-primary)] tracking-tight !m-0 leading-none"
            >
                {title}
            </h3>
        </div>
        <div
            class="text-[var(--sl-color-gray-2)] leading-relaxed text-[0.925rem] group-hover:text-[var(--sl-color-gray-1)] transition-colors duration-500 relative z-10"
        >
            <slot />
        </div>
    </div>
</div>
