---
interface Props {
    number: string | number;
    title: string;
    variant?: "purple" | "pink" | "cyan" | "green" | "orange" | "yellow";
}

const { number, title, variant = "purple" } = Astro.props;

const colors = {
    purple: { bg: "bg-[var(--purple)]", text: "text-[var(--purple)]" },
    pink: { bg: "bg-[var(--purple)]", text: "text-[var(--purple)]" },
    cyan: { bg: "bg-[var(--blue)]", text: "text-[var(--blue)]" },
    green: { bg: "bg-[var(--green)]", text: "text-[var(--green)]" },
    orange: { bg: "bg-[var(--orange)]", text: "text-[var(--orange)]" },
    yellow: { bg: "bg-[var(--yellow)]", text: "text-[var(--yellow)]" },
    red: { bg: "bg-[var(--red)]", text: "text-[var(--red)]" },
};

const color = colors[variant] || colors.purple;
---

<h2
    class={`text-2xl font-bold ${color.text} mt-12 mb-4 flex items-center gap-2`}
>
    <span
        class={`${color.bg} text-white w-8 h-8 rounded-full flex items-center justify-center text-sm mr-3 shadow-lg`}
    >
        {number}
    </span>
    {title}
</h2>
